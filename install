pcver="5.0β"
updated=0

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR

pc_has_dialog=0
PC_RUN_USER="${1:-}"
readonly PC_RUN_USER

PC_INSTALL_ACTION="new"
PC_EXISTING_INSTALL=""
PC_GAMEMODE="survival"
PC_LEVELTYPE="normal"
PC_AUTOLOAD=1

# Get the LAN IP address
# test the route based on $host and treat that as the interface
interface=""
host=github.com
host_ip=$(getent ahosts "$host" | awk '{print $1; exit}')
interface=`ip route get "$host_ip" | grep -Po '(?<=(dev )).*(?= src| proto)' | cut -f 1 -d " "`
ip=$(/sbin/ip -f inet addr show $interface | grep -Po 'inet \K[\d.]+' | head -n 1)
if [[ $ip == "" ]]; then
  # Never reply with a blank string - instead, use localhost if no IP is found
  # This would be the case if no network connection is present
  ip="127.0.0.1"
fi

source "${SCRIPT_DIR}/lib/ui.sh"
source "${SCRIPT_DIR}/lib/preflight.sh"
source "${SCRIPT_DIR}/lib/java_manager.sh"
source "${SCRIPT_DIR}/lib/metadata.sh"
source "${SCRIPT_DIR}/lib/seeds.sh"
source "${SCRIPT_DIR}/lib/providers/common.sh"
source "${SCRIPT_DIR}/lib/providers/vanilla.sh"
source "${SCRIPT_DIR}/lib/providers/paper.sh"
source "${SCRIPT_DIR}/lib/providers/purpur.sh"
source "${SCRIPT_DIR}/lib/providers/fabric.sh"
source "${SCRIPT_DIR}/lib/providers/forge.sh"
source "${SCRIPT_DIR}/lib/providers/spigot.sh"
source "${SCRIPT_DIR}/lib/providers/cuberite.sh"
source "${SCRIPT_DIR}/lib/installers.sh"
source "${SCRIPT_DIR}/lib/runtime.sh"

pc_bootstrap_dependencies() {
  # Check for required packages
  local -a missing=()
  local cmd
  for cmd in dialog curl jq ca-certificates git tar gzip screen openssl procps lsb_release sudo ip python3 ss bc; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
      missing+=("$cmd")
    fi
  done

  if [[ ${#missing[@]} -eq 0 ]]; then
    command -v dialog > /dev/null 2>&1 && pc_has_dialog=1 || true
    return 0
  fi

  if ! command -v apt-get > /dev/null 2>&1; then
    echo "ERROR: apt-get is not available on this system."
    echo "Pinecraft requires a Debian Stable-based operating system with apt-get."
    exit 1
  fi

  export DEBIAN_FRONTEND=noninteractive

  if [[ $updated == 0 ]]; then
    echo "Running apt-get update..."
    apt-get update
    updated=1
  fi

  echo "Installing required packages..."
  apt-get -y install \
    dialog curl jq ca-certificates git tar gzip screen openssl procps coreutils \
    util-linux lsb-release sudo iproute2 python3 bc

  if command -v dialog > /dev/null 2>&1; then
    pc_has_dialog=1
  else
    echo "ERROR: dialog is still unavailable after dependency installation."
    exit 1
  fi
}

pc_require_root() {
  if [[ ${EUID} -ne 0 ]]; then
    echo "ERROR: Pinecraft Installer must be run as root. Try: sudo $0" 2>&1
    exit 1
  fi
}

pc_show_welcome() {
  dialog --title "Pinecraft Installer ${pcver}" \
    --msgbox "\nPinecraft: The Minecraft Server Installer\n\nFor Raspberry Pi and Other SBCs\n\nBy Robbie Ferguson // The Bald Nerd\n\nhttps://category5.tv/feature/minecraft\n\nInstaller Version: ${pcver}\n\n" 16 54
}

pc_show_bare_metal_warning() {
  if ! dialog --title "WARNING" \
    --yes-label "I Understand" \
    --no-label "Exit" \
    --yesno "\nWARNING: Pinecraft is a bare-metal installer.\n\nInstalling Pinecraft will convert this computer into a dedicated Minecraft server host.\n\nIt is not designed for laptops, desktops, workstations, or computers that perform other roles.\n\nPinecraft will attempt to optimize the OS and prioritize available system resources for Minecraft server performance. This includes taking over system resources indefinitely for Minecraft hosting.\n\nReturning this computer to normal use will generally require wiping the system and reinstalling the base operating system from scratch.\n\nIf you continue, you acknowledge that this machine is being dedicated to Minecraft server hosting.\n" 20 72; then
    pc_cancelled
  fi
}

pc_show_support_pinecraft() {
  dialog --title "Support the Pinecraft Project" \
    --msgbox "\nPinecraft is developed and maintained by one person.\nDevelopment, testing, hosting, and infrastructure all come out of pocket.\n\nIf Pinecraft has helped you set up a Minecraft server, please consider supporting the project.\n\nCommunity support helps keep development moving forward and keeps the hosted high-performance Pinecraft server available.\n\nhttps://patreon.com/Pinecraft\n\nThank you for supporting independent open source development.\n" 16 72
}

pc_wait_transition() {
  clear
  sleep 0.1
}

pc_cancelled() {
  clear
  echo "Pinecraft Installer cancelled"
  exit 0
}

pc_user_exists() {
  local user="$1"
  [[ -n "$user" ]] || return 1
  getent passwd "$user" > /dev/null 2>&1
}

pc_select_linux_user() {
  local selected="${PC_RUN_USER:-}"
  local homedir
  local -a usersarr=()
  local username

  if pc_user_exists "$selected"; then
    homedir="$(getent passwd "$selected" | cut -d: -f6)"
    if [[ -d "$homedir" ]]; then
      echo "$selected"
      return 0
    fi
  fi

  while IFS=: read -r username _ _ _ _ homedir _; do
    [[ "$homedir" == /home/* ]] || continue
    [[ -d "$homedir" ]] || continue
    usersarr+=("$username" "$homedir")
  done < /etc/passwd

  if [[ ${#usersarr[@]} -eq 0 ]]; then
    dialog --title "Error" --msgbox "\nNo valid Linux users with home directories were found under /home.\n" 8 60
    return 1
  fi

  selected=$(dialog --stdout --title "Linux User" \
    --menu "Linux user to run the Minecraft server:" 20 60 12 \
    "${usersarr[@]}") || true

  [[ -n "$selected" ]] || return 1

  if ! pc_user_exists "$selected"; then
    dialog --title "Error" --msgbox "\n${selected} does not exist.\n" 6 50
    return 1
  fi

  homedir="$(getent passwd "$selected" | cut -d: -f6)"
  if [[ ! -d "$homedir" ]]; then
    dialog --title "Error" --msgbox "\n${selected} does not have a valid home directory.\n" 7 60
    return 1
  fi

  echo "$selected"
}

pc_current_install_dir() {
  echo "/srv/pinecraft/server"
}

pc_current_install_value() {
  local key="$1"
  local meta="$(pc_current_install_dir)/.pinecraft-install.json"
  local latest

  if [[ -f "$meta" ]]; then
    jq -r --arg k "$key" '.[$k] // empty' "$meta" 2>/dev/null || true
    return 0
  fi

  latest="$(ls -1t /opt/pinecraft/metadata/*.json 2>/dev/null | head -n 1 || true)"
  if [[ -n "$latest" && -f "$latest" ]]; then
    jq -r --arg k "$key" '.[$k] // empty' "$latest" 2>/dev/null || true
  fi
}

pc_is_minecraft_downgrade() {
  local current_version="$1"
  local target_version="$2"
  local current_idx=-1
  local target_idx=-1
  local idx=0
  local v
  local -a versions=()

  [[ -n "$current_version" && -n "$target_version" ]] || return 1
  mapfile -t versions < <(pc_vanilla_list_versions 2>/dev/null || true)
  [[ ${#versions[@]} -gt 0 ]] || return 1

  for v in "${versions[@]}"; do
    if [[ "$v" == "$current_version" ]]; then current_idx=$idx; fi
    if [[ "$v" == "$target_version" ]]; then target_idx=$idx; fi
    idx=$((idx + 1))
  done

  [[ $current_idx -ge 0 && $target_idx -ge 0 ]] || return 1
  [[ $target_idx -gt $current_idx ]]
}

pc_select_install_action_for_target() {
  local flavour="$1"
  local version="$2"
  local target
  local current_version current_flavour current_user title prompt
  local action
  local -a menu=()

  target="$(pc_current_install_dir)"
  PC_EXISTING_INSTALL=""
  PC_INSTALL_ACTION="new"

  if [[ ! -e "$target/cat5tv.ver" ]]; then
    return 0
  fi

  PC_EXISTING_INSTALL="$target"
  current_version="$(pc_current_install_value minecraft_version)"
  current_flavour="$(pc_current_install_value flavour)"
  current_user="$(pc_current_install_value run_user)"

  title="Existing Installation Found"
  prompt="A Pinecraft server is already installed at ${target}."
  if [[ -n "$current_flavour" || -n "$current_version" ]]; then
    prompt+="

Current server: ${current_flavour:-unknown} ${current_version:-unknown}"
  fi
  prompt+="
Target server: ${flavour} ${version}"
  if [[ -n "$current_user" ]]; then
    prompt+="
Linux user: ${current_user}"
  fi

  if pc_is_minecraft_downgrade "$current_version" "$version"; then
    menu+=("replace" "Remove Previous and Reinstall")
    prompt+="

Downgrading Minecraft versions may break an existing world. Keep World is not available for this downgrade."
  else
    menu+=("upgrade" "Upgrade or Switch Server (Keep World)")
    menu+=("replace" "Remove Previous and Reinstall")
  fi

  action=$(dialog --stdout --title "$title"     --menu "$prompt" 18 76 6     "${menu[@]}") || true

  [[ -n "$action" ]] || return 1

  if [[ "$action" == "replace" ]]; then
    dialog --title "Confirmation" --yes-label "Continue" --no-label "Cancel" --yesno "
This will remove the existing Pinecraft server and reinstall ${flavour} ${version} in the same target folder.

Continue?
" 10 72 || return 1
  fi

  PC_INSTALL_ACTION="$action"
}

pc_show_flavour_menu() {
  local choice
  local key
  local label
  local desc
  local index=1
  local default_item="1"
  local -a menu=()
  local -a flavour_map=()

  while IFS='|' read -r key label desc; do
    menu+=("${index}" "${label} - ${desc}")
    flavour_map[$index]="$key"

    if [[ "$key" == "paper" ]]; then
      default_item="$index"
    fi

    index=$((index + 1))
  done < <(pc_provider_menu_entries)

  choice=$(dialog --stdout --title "Choose Server Type" \
    --default-item "$default_item" \
    --menu "Choose the type of Minecraft server you want to install." 22 86 12 \
    "${menu[@]}") || true

  [[ -n "$choice" ]] || return 1
  echo "${flavour_map[$choice]}"
}

pc_show_seed_menu() {
  local flavour="$1"
  local choice
  local seed_id
  local seed_name
  local seed_desc
  local -a menu=()
  local index=1

  menu+=("1" "Random Seed - Let Minecraft generate one for you")
  menu+=("2" "Custom Seed - Enter your own seed value")

  local hidden_count=0
  hidden_count=$(pc_seed_hidden_count_for_flavour "$flavour")

  while IFS='|' read -r seed_id seed_name seed_desc; do
    index=$((index + 1))
    menu+=("${index}" "${seed_name} - ${seed_desc}")
  done < <(pc_seed_menu_entries_for_flavour "$flavour")

  local prompt="Choose a curated seed, enter your own, or generate a random seed."
  if [[ ${hidden_count:-0} -gt 0 ]]; then
    prompt="Choose a curated seed, enter your own, or generate a random seed.\n\nSome seeds are hidden because they are not compatible with ${flavour}."
  fi

  choice=$(dialog --stdout --no-tags --title "Game Seed" \
    --menu "$prompt" 22 90 14 \
    "${menu[@]}") || true

  [[ -n "$choice" ]] || return 1

  if [[ "$choice" == "1" ]]; then
    printf 'random|Random Seed|RANDOM|*|highest_patch\n'
    return 0
  fi

  if [[ "$choice" == "2" ]]; then
    local seed
    seed=$(dialog --stdout --title "Custom Seed" --inputbox "Enter your seed value:" 10 60) || true
    [[ -n "$seed" ]] || return 1
    printf 'custom|Custom Seed|%s|*|highest_patch\n' "$seed"
    return 0
  fi

  local seed_index=$((choice - 3))
  pc_seed_get_record_by_index "$seed_index"
}

pc_show_version_mode_menu() {
  local label="$1"
  local seed_id="$2"
  local choice
  local latest_label="Latest version"

  if [[ "$seed_id" != "random" && "$seed_id" != "custom" && "$seed_id" != "existing" ]]; then
    latest_label="Latest version compatible with this seed"
  fi

  choice=$(dialog --stdout --title "$label" \
    --menu "Choose how you want Pinecraft to select the Minecraft version." 14 70 4 \
    "latest" "${latest_label}" \
    "specific" "Choose a specific Minecraft version") || true

  echo "$choice"
}

pc_show_version_details_notice() {
  local details="$1"
  dialog --title "Compatibility Info" --msgbox "\nSome versions are hidden because this system does not currently meet their requirements.\n\n${details}\n\nUpdating or correcting the underlying OS may make additional Minecraft versions and server flavours available.\n" 15 76
}

pc_choose_version_for_flavour() {
  local flavour="$1"
  local seed_versions="$2"
  local seed_policy="$3"
  local mode="$4"
  local -a versions=()
  local -a filtered=()
  local version

  mapfile -t versions < <(pc_provider_list_versions "$flavour")
  if [[ ${#versions[@]} -eq 0 ]]; then
    dialog --title "Error" --msgbox "\nNo versions are currently available for ${flavour}.\n" 8 50
    return 1
  fi

  mapfile -t filtered < <(pc_seed_filter_versions "$seed_versions" "$seed_policy" "${versions[@]}")
  if [[ ${#filtered[@]} -eq 0 ]]; then
    dialog --title "Seed Compatibility" --msgbox "\nNo compatible versions were found for that seed and server type.\n" 8 60
    return 1
  fi

  if [[ "$mode" == "latest" ]]; then
    echo "${filtered[0]}"
    return 0
  fi

  local -a menu=()
  local v
  for v in "${filtered[@]}"; do
    menu+=("$v" "Install ${flavour} ${v}")
  done

  version=$(dialog --stdout --title "Choose Minecraft Version" \
    --menu "Choose a compatible Minecraft version." 22 72 14 \
    "${menu[@]}") || true

  [[ -n "$version" ]] || return 1
  echo "$version"
}

pc_show_leveltype_menu() {
  local result
  result=$(dialog --stdout --title "World Type" \
    --menu "Choose your level type:" 20 48 10 \
    "normal" "Normal (Default)" \
    "flat" "Super Flat" \
    "large_biomes" "Large Biomes" \
    "amplified" "Amplified" \
    "single_biome_surface" "Single Biome Surface") || true
  echo "$result"
}

pc_show_gamemode_menu() {
  local result
  result=$(dialog --stdout --title "Game Type" \
    --menu "Choose your game type:" 18 44 8 \
    "survival" "Survival" \
    "creative" "Creative" \
    "adventure" "Adventure") || true
  echo "$result"
}

pc_show_boot_menu() {
  local rc
  dialog --title "Server Startup" \
    --yes-label "Yes" \
    --no-label "No" \
    --yesno "
 Automatically load the Minecraft server on boot?
" 8 56
  rc=$?
  case "$rc" in
    0)
      PC_AUTOLOAD=1
      ;;
    1)
      PC_AUTOLOAD=0
      ;;
    *)
      return 1
      ;;
  esac
  return 0
}

pc_show_eula_prompt() {
  # If the user does not accept the Minecraft EULA, they are not permitted to proceed
  local tmpfile
  local eula_text
  tmpfile="$(mktemp)"
  cat > "$tmpfile" <<'EULA'
Minecraft End User License Agreement (EULA)

This installer requires that you accept Mojang's Minecraft EULA before the server
can be installed and started.

Summary:

- The Minecraft EULA and the Microsoft Services Agreement apply to Minecraft.
- You may host the Java Edition server and play online with others.
- Mods, plugins, and tools are allowed when they are original work and do not
  redistribute Mojang code or content.
- You must not distribute Minecraft software or content, or make commercial use
  of it except as permitted by Mojang and Microsoft.
- Mojang and Microsoft may update these terms from time to time.

Official EULA:
https://www.minecraft.net/eula
EULA
  eula_text="$(cat "$tmpfile")"
  rm -f "$tmpfile"
  dialog --title "Minecraft EULA" --ok-label "Continue" --msgbox "$eula_text" 20 76 || return 1
  dialog --title "Accept Minecraft EULA" --yes-label "Accept" --no-label "Decline" --yesno "
Do you accept the Minecraft EULA in order to continue with installation?
" 8 60
}


pc_choose_build_if_needed() {
  local flavour="$1"
  local version="$2"

  case "$flavour" in
    paper)
      pc_paper_list_builds "$version" | head -n 1
      ;;
    purpur)
      pc_purpur_list_builds "$version" | head -n 1
      ;;
    fabric)
      pc_fabric_list_builds "$version" | head -n 1
      ;;
    *)
      echo "latest"
      ;;
  esac
}

pc_show_install_summary() {
  local flavour="$1"
  local version="$2"
  local build="$3"
  local required_java="$4"
  local seed_name="$5"
  local support_status="$6"
  local gamemode="$7"
  local leveltype="$8"
  local autoload="$9"

  local autoload_text="No"
  [[ "$autoload" == "1" ]] && autoload_text="Yes"

  dialog --title "Install Summary" --yes-label "Install" --no-label "Cancel" --yesno "\nYou selected ${flavour} ${version}\n\nBuild: ${build}\nSeed: ${seed_name}\nGame Type: ${gamemode}\nWorld Type: ${leveltype}\nRequired Java: ${required_java}\nAuto-Start On Boot: ${autoload_text}\nPinecraft will install and configure this automatically.\n\nPlatform status: ${support_status}\n\nContinue with installation?\n" 20 66
}

pc_main() {
  pc_require_root
  pc_phase "Preparing system..."
  pc_bootstrap_dependencies

  pc_show_welcome
  pc_show_bare_metal_warning
  pc_show_support_pinecraft

  pc_phase "Checking platform and connectivity..."
  pc_preflight_run
  pc_preflight_render_summary
  pc_wait_transition

  local run_user
  run_user=$(pc_select_linux_user)
  [[ -n "$run_user" ]] || pc_cancelled

  if [[ $PF_IS_RPI -eq 1 ]]; then
    pc_show_pi_overclock_prompt || true
  fi

  local hidden_details
  hidden_details="$(pc_provider_hidden_details || true)"
  if [[ -n "$hidden_details" ]]; then
    pc_show_version_details_notice "$hidden_details"
    pc_wait_transition
  fi

  local flavour
  flavour=$(pc_show_flavour_menu)
  [[ -n "$flavour" ]] || pc_cancelled

  local seed_record seed_id seed_name seed_value seed_versions seed_policy
  seed_record=$(pc_show_seed_menu "$flavour")
  [[ -n "$seed_record" ]] || pc_cancelled
  IFS='|' read -r seed_id seed_name seed_value seed_versions seed_policy <<< "$seed_record"

  local mode
  mode=$(pc_show_version_mode_menu "$flavour" "$seed_id")
  [[ -n "$mode" ]] || pc_cancelled

  local version
  pc_phase "Fetching available Minecraft versions..."
  version=$(pc_choose_version_for_flavour "$flavour" "$seed_versions" "$seed_policy" "$mode")
  [[ -n "$version" ]] || pc_cancelled

  pc_select_install_action_for_target "$flavour" "$version" || pc_cancelled
  if [[ "$PC_INSTALL_ACTION" == "upgrade" ]]; then
    seed_name="Keep Existing World"
    seed_value=""
  fi

  local leveltype
  leveltype=$(pc_show_leveltype_menu)
  [[ -n "$leveltype" ]] || pc_cancelled
  PC_LEVELTYPE="$leveltype"

  local gamemode
  gamemode=$(pc_show_gamemode_menu)
  [[ -n "$gamemode" ]] || pc_cancelled
  PC_GAMEMODE="$gamemode"

  pc_show_eula_prompt || pc_cancelled
  pc_show_boot_menu || pc_cancelled

  local build
  pc_phase "Resolving server build..."
  build=$(pc_choose_build_if_needed "$flavour" "$version")
  [[ -n "$build" ]] || pc_cancelled

  local required_java
  required_java=$(pc_java_required_for_mc "$version")

  if ! pc_show_install_summary "$flavour" "$version" "$build" "$required_java" "$seed_name" "$PF_STATUS_LABEL" "$gamemode" "$leveltype" "$PC_AUTOLOAD"; then
    pc_cancelled
  fi

  pc_phase "Installing Java ${required_java}..."
  pc_ensure_java_major "$required_java"

  pc_phase "Optimizing the system for Minecraft hosting..."
  pc_apply_host_optimizations

  pc_phase "Installing ${flavour} ${version}..."
  local install_path
  install_path=$(pc_install_selected_server "$run_user" "$flavour" "$version" "$build" "$seed_name" "$seed_value" "$required_java" "$gamemode" "$leveltype" "$PC_INSTALL_ACTION" "$PC_EXISTING_INSTALL") || pc_cancelled

  pc_metadata_save_install "$install_path" "$flavour" "$version" "$build" "$required_java" "$seed_name" "$seed_value" "$run_user" "$gamemode" "$leveltype" "$PC_AUTOLOAD" "$PC_INSTALL_ACTION"

  pc_phase "Activating the installed server..."
  if [[ -x /usr/local/bin/pinecraft ]]; then
    /usr/local/bin/pinecraft stop > /dev/null 2>&1 || true
  fi
  pc_runtime_activate_install "$install_path"
  pc_runtime_install_helpers
  pc_runtime_install_service

  if command -v systemctl > /dev/null 2>&1; then
    systemctl daemon-reload > /dev/null 2>&1 || true
    if [[ "$PC_AUTOLOAD" == "1" ]]; then
      systemctl enable pinecraft.service > /dev/null 2>&1 || true
    else
      systemctl disable pinecraft.service > /dev/null 2>&1 || true
    fi
    systemctl restart pinecraft.service > /dev/null 2>&1 || true
  else
    /usr/local/bin/pinecraft start > /dev/null 2>&1 || true
  fi

  dialog --title "Success" --msgbox "
 Pinecraft installation is complete.

 Installed to: ${install_path}
 Active server: /srv/pinecraft/current

 Runtime commands:
   pinecraft start
   pinecraft stop
   pinecraft restart
   pinecraft console
   pinecraft status

 If this project saved you time or made your life easier, please consider supporting its continued development:

 https://patreon.com/Pinecraft
" 18 72

  clear
}

pc_main "$@"

clear
echo
echo "Installation complete."
echo
echo "Minecraft server is now running on $ip"
echo "Remember: World generation can take a few minutes. Be patient."
echo
echo "Documentation: https://github.com/Cat5TV/Pinecraft"
echo
echo "Pinecraft Installer is created by Robbie Ferguson // The Bald Nerd"
echo "Support Me: https://patreon.com/Pinecraft"
echo
